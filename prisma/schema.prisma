generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id             String    @id @default(uuid())
  name           String
  description    String
  location       String
  image          String
  facilities     String
  gallery        String?
  hasDayoutRates Boolean   @default(false)
  nearbyPlaces   String?
  slug           String?   @unique
  bookings       Booking[]
  rooms          Room[]
}

model Room {
  id          String    @id @default(uuid())
  hotelId     String
  roomName    String
  price       Float
  capacity    Int
  status      String
  image       String
  facilities  String
  dayoutPrice Float?
  totalUnits  Int       @default(1)
  bookings    Booking[]
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model Booking {
  id            String    @id @default(uuid())
  reservationId String    @unique
  customerName  String
  phone         String
  email         String
  customerId    String?
  hotelId       String
  roomId        String
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  status        String
  bookingType   String    @default("Night Stay") // "Night Stay" | "Day Out"
  totalAmount   Float
  createdAt     DateTime  @default(now())
  customer      Customer? @relation(fields: [customerId], references: [id])
  hotel         Hotel     @relation(fields: [hotelId], references: [id])
  room          Room      @relation(fields: [roomId], references: [id])
  payments      Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String
  amount        Float
  paymentMethod String
  paymentStatus String
  receiptUrl    String?
  transactionId String?
  createdAt     DateTime @default(now())
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Admin {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  employeeId String   @unique
  role       String   @default("admin")
  createdAt  DateTime @default(now())
  hasAccess  Boolean  @default(true)
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String
  password  String
  createdAt DateTime  @default(now())
  bookings  Booking[]
}
