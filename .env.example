# ============================================================
# Kumara Hotels — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# PostgreSQL connection string (Prisma).
# For Supabase: use the Transaction Mode pooler on port 6543.
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ------------------------------------------------------------
# SECURITY
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required for signing any future JWT / session tokens.
# ------------------------------------------------------------
JWT_SECRET="replace-with-a-long-random-secret"

# ------------------------------------------------------------
# CONTACT DETAILS (server-side, used in notification emails)
# ------------------------------------------------------------
CONCIERGE_EMAIL="your-email@example.com"
WHATSAPP_NUMBER="+94 XX XXX XXXX"

# ------------------------------------------------------------
# CONTACT DETAILS (client-side, displayed in Footer & Widget)
# Prefix NEXT_PUBLIC_ so they are exposed to the browser.
# ------------------------------------------------------------
NEXT_PUBLIC_CONTACT_PHONE="+94 XX XXX XXXX"
NEXT_PUBLIC_CONTACT_EMAIL="your-email@example.com"

# WhatsApp number in international format WITHOUT the leading +
# Example: 94771234567 for +94 77 123 4567
NEXT_PUBLIC_WHATSAPP_NUMBER="94XXXXXXXXX"

# ------------------------------------------------------------
# OPTIONAL — Email delivery (future integration)
# ------------------------------------------------------------
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="no-reply@yourdomain.com"

# ------------------------------------------------------------
# NODE ENVIRONMENT
# Set to "production" when deploying. Never use "development".
# ------------------------------------------------------------
NODE_ENV="production"
