# ============================================================
# Kumara Hotels — Environment Variables
# Copy this file to .env and fill in the real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# PostgreSQL connection string (Prisma).
# For Supabase: use the Transaction Mode pooler on port 6543.
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ------------------------------------------------------------
# CONTACT DETAILS (server-side, used in notification emails)
# ------------------------------------------------------------
CONCIERGE_EMAIL="concierge@kumarahotels.com"
WHATSAPP_NUMBER="+94 72 719 1184"

# ------------------------------------------------------------
# CONTACT DETAILS (client-side, displayed in Footer)
# Prefix with NEXT_PUBLIC_ so they are exposed to the browser.
# ------------------------------------------------------------
NEXT_PUBLIC_CONTACT_PHONE="+94 11 234 5678"
NEXT_PUBLIC_CONTACT_EMAIL="concierge@kumarahotels.com"

# ------------------------------------------------------------
# WHATSAPP WIDGET
# The hotel's WhatsApp number in international format without
# the leading +. Example: 94727191184 for +94 72 719 1184.
# This value is embedded in the client bundle (NEXT_PUBLIC_).
# ------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER="94727191184"

# ------------------------------------------------------------
# OPTIONAL — Email delivery (future integration)
# Uncomment and fill in when Resend / SendGrid is wired up.
# ------------------------------------------------------------
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="no-reply@kumarahotels.com"

# ------------------------------------------------------------
# OPTIONAL — Next.js
# Set to "production" when deploying to a live environment.
# ------------------------------------------------------------
# NODE_ENV="development"
